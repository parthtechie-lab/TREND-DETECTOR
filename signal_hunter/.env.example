# ─────────────────────────────────────────────────────────────────────────────
# Signal Hunter AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Reddit API (Tier A) ────────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=SignalHunterAI/1.0 by /u/your_username

# ── YouTube API (Tier A) ───────────────────────────────────────────────────────
# Enable YouTube Data API v3 at https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key

# ── Product Hunt API (Tier B) ──────────────────────────────────────────────────
# Register at https://www.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_API_KEY=your_product_hunt_api_key
PRODUCT_HUNT_API_SECRET=your_product_hunt_api_secret

# ── OpenAI API ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Model tiers:
# Fast/cheap for first-pass classification (Haiku-class)
CLASSIFIER_MODEL=gpt-4o-mini
# Strong model for corroborated trend summaries only
SUMMARIZER_MODEL=gpt-4o

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, good for development)
DATABASE_URL=sqlite+aiosqlite:///./signal_hunter.db

# PostgreSQL (recommended for production with multiple AI workers)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/signal_hunter

# ── AI Confidence Thresholds ───────────────────────────────────────────────────
# Items above this AND corroborated → real-time Telegram alert
CONFIDENCE_THRESHOLD_ALERT=0.8
# Items above this → stored + included in digest only
CONFIDENCE_THRESHOLD_STORE=0.5

# ── Queue Sizes ────────────────────────────────────────────────────────────────
RAW_QUEUE_MAXSIZE=500
UNIQUE_QUEUE_MAXSIZE=200
SCORED_QUEUE_MAXSIZE=200

# ── Worker Counts ──────────────────────────────────────────────────────────────
# Scale AI workers up to your LLM rate limit (not CPU count)
AI_WORKER_COUNT=3

# ── Deduplication ──────────────────────────────────────────────────────────────
# Cosine similarity threshold for semantic dedup (0.92 = very similar)
SEMANTIC_DEDUP_THRESHOLD=0.92
# Rolling window size for semantic comparison
SEMANTIC_WINDOW_SIZE=500

# ── Corroboration ──────────────────────────────────────────────────────────────
# Minimum distinct sources required to label an item "exploding trend"
CORROBORATION_MIN_SOURCES=2
# Rolling window in hours for corroboration check
CORROBORATION_WINDOW_HOURS=48

# ── Alerting ───────────────────────────────────────────────────────────────────
# Digest window in seconds (default: 5 minutes)
ALERT_BATCH_WINDOW_SECONDS=300

# ── Tier C (Playwright) ────────────────────────────────────────────────────────
# Set to true to enable TikTok headless scraping (Tier C, high-risk)
PLAYWRIGHT_ENABLED=false

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
METRICS_PORT=9090
DASHBOARD_PORT=8080
